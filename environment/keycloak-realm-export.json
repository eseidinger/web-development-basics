{
  "realm": "taskboard",
  "enabled": true,
  "displayName": "Task Board",
  "accessTokenLifespan": 300,
  "accessCodeLifespan": 60,
  "accessCodeLifespanUserAction": 300,
  "actionTokenGeneratedByAdminLifespan": 43200,
  "actionTokenGeneratedByUserLifespan": 300,
  "clients": [
    {
      "clientId": "taskboard-api",
      "name": "Task Board API",
      "description": "Backend API service",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "taskboard-api-secret-dev-only-change-in-prod",
      "publicClient": false,
      "bearerOnly": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "redirectUris": [
        "http://localhost:8080/*"
      ],
      "webOrigins": [
        "http://localhost:8080"
      ]
    },
    {
      "clientId": "taskboard-frontend",
      "name": "Task Board Frontend",
      "description": "Single Page Application",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "publicClient": true,
      "bearerOnly": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:4200/*",
        "http://localhost:5173/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:4200",
        "http://localhost:5173"
      ]
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "user",
        "description": "Base user role - granted to all users"
      },
      {
        "name": "admin",
        "description": "System administrator - can manage all boards and users globally"
      }
    ]
  },
  "users": [
    {
      "username": "alice",
      "firstName": "Alice",
      "lastName": "Owner",
      "email": "alice@taskboard.local",
      "emailVerified": true,
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user",
        "admin"
      ]
    },
    {
      "username": "bob",
      "firstName": "Bob",
      "lastName": "Member",
      "email": "bob@taskboard.local",
      "emailVerified": true,
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user"
      ]
    },
    {
      "username": "charlie",
      "firstName": "Charlie",
      "lastName": "Viewer",
      "email": "charlie@taskboard.local",
      "emailVerified": true,
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user"
      ]
    }
  ]
}
